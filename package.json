{
  "name": "agents-md-xray",
  "version": "0.1.3",
  "description": "CLI and CI checker for AGENTS.md quality, drift, and agent instruction safety.",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "agents-md-xray": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "ci": "pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "agents-md",
    "AGENTS.md",
    "codex",
    "ai-agents",
    "coding-agents",
    "github-action",
    "developer-tools",
    "agent-instructions"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
